## Server Configuration
PORT=3777

## Database Credentials
DB_USER=your_database_user
DB_PASS=your_database_password
DB_HOST=127.0.0.1
DB_NAME=your_database_name

## JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=1d


## Gemini API (Used for Vector Embeddings)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
## Optional: text model for draft coach + answer fit (defaults to gemini-2.5-flash-lite)
GEMINI_TEXT_MODEL=gemini-2.5-flash-lite



## Vector Search Thresholds & Settings
# Threshold for recommending similar questions
RECOMMEND_THRESHOLD=0.75
# Number of similar questions to return
RECOMMEND_K=5

## RAG (user-owned PDFs)
# Where PDFs are stored on disk (default uploads/rag under backend cwd)
RAG_UPLOAD_DIR=uploads/rag
# Max upload size in megabytes (keep small for classroom demos)
RAG_MAX_UPLOAD_MB=5
# Chunking: character window and overlap between windows
RAG_CHUNK_CHARS=900
RAG_CHUNK_OVERLAP=120
# Safety caps per document / per user
RAG_MAX_CHUNKS_PER_DOC=1000
RAG_MAX_PDFS_PER_USER=20
# Minimum extracted characters to treat PDF as usable text
RAG_MIN_TEXT_CHARS=50
# Semantic search: min cosine score and max hits returned
RAG_SEARCH_THRESHOLD=0.45
RAG_SEARCH_K=10
