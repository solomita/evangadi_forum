# # Server
# PORT=5004
# FRONTEND_URL=http://localhost:5000

# # Database
# DB_HOST=localhost
# DB_USER=root
# DB_PASSWORD=
# # DB_PASS is also supported as a local-dev alias.
# DB_NAME=evangadi_forum

# # JWT — required, no default (server will refuse to start without this)
# JWT_SECRET=your_jwt_secret_here
# JWT_EXPIRES_IN=1d
