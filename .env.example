# Variables consumed by docker-compose.yml (copy to .env and fill in).
# Docker Compose reads .env from this directory automatically.

# MySQL container
MYSQL_ROOT_PASSWORD=change_me_root
DB_NAME=evangadi_forum
DB_USER=forum_user
DB_PASSWORD=change_me
# Host port the db is published on (container always listens on 3306).
DB_PORT=3309
